<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/textDisplayCount"
        android:layout_width="196dp"
        android:layout_height="297dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:background="#2196F3"
        android:gravity="center"
        android:text="@string/count_value"
        android:textColor="@color/text_main"
        android:textSize="150sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/buttonZero"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.316" />

    <Button
        android:id="@+id/button_toast"
        android:layout_width="100dp"
        android:layout_height="59dp"
        android:layout_marginStart="8dp"
        android:backgroundTint="@color/primary"
        android:onClick="show_toast"
        android:text="@string/toast"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="0dp"
        app:layout_constraintEnd_toStartOf="@+id/textDisplayCount"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/textDisplayCount" />

    <Button
        android:id="@+id/buttonZero"
        android:layout_width="100dp"
        android:layout_height="59dp"
        android:layout_marginStart="8dp"
        android:backgroundTint="#9E9E9E"
        android:onClick="showZero"
        android:text="@string/zero"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="0dp"
        app:layout_constraintBottom_toTopOf="@id/buttonCount"
        app:layout_constraintEnd_toStartOf="@id/textDisplayCount"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/button_toast" />

    <Button
        android:id="@+id/buttonCount"
        android:layout_width="100dp"
        android:layout_height="59dp"
        android:layout_marginStart="8dp"
        android:backgroundTint="@color/primaryDark"
        android:onClick="increase_count"
        android:text="@string/count"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="0dp"
        app:layout_constraintBottom_toBottomOf="@id/textDisplayCount"
        app:layout_constraintEnd_toStartOf="@id/textDisplayCount"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/buttonZero" />
</androidx.constraintlayout.widget.ConstraintLayout>